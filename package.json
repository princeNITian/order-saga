    "package": "npm run bundle && npm run zip",
    "deploy": "node scripts/deploy.mjs",
    "release": "npm run package && npm run deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/princeNITian/order-saga.git"
  },
